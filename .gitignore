# Dependencies — reinstall with npm install
node_modules/

# Build output — regenerated by npm run build
dist/

# Netlify local dev cache
.netlify/

# Environment variables — never commit secrets
.env
.env.local
.env.*.local

# OS junk
.DS_Store
Thumbs.db
Desktop.ini

# Editor directories
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Test coverage
coverage/

# TypeScript cache
*.tsbuildinfo
